<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.zakilb.servicemanager.ui.controllers.OrdersController"
      spacing="10" style="-fx-padding: 15;">
    
    <!-- Top: Filters and Actions -->
    <VBox spacing="10">
        <!-- Title, Search and New Order Button -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="workOrdersTitleLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search..." prefWidth="250"/>
            <Button fx:id="searchButton" text="Search" onAction="#handleSearch"/>
            <Button fx:id="newOrderButton" onAction="#handleNewOrder" 
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" 
                    prefWidth="150"/>
        </HBox>
        
        <!-- Filters -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="filterByLabel"/>
            <Label fx:id="statusFilterLabel"/>
            <ComboBox fx:id="statusFilter" prefWidth="150"/>
            
            <Label fx:id="createdFromLabel"/>
            <DatePicker fx:id="dateFromPicker" prefWidth="140"/>

            <Label fx:id="toLabel1"/>
            <DatePicker fx:id="dateToPicker" prefWidth="140"/>

            <Label fx:id="dueFromLabel"/>
            <DatePicker fx:id="dueDateFromPicker" prefWidth="140"/>

            <Label fx:id="toLabel2"/>
            <DatePicker fx:id="dueDateToPicker" prefWidth="140"/>
            
            <Button fx:id="filterButton" onAction="#handleFilter"/>
            <Button fx:id="clearFilterButton" onAction="#handleClearFilter"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="refreshButton" onAction="#handleRefresh"/>
        </HBox>
    </VBox>
    
    <!-- Center: Table with Translated Column Headers -->
    <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="orderNumberColumn" prefWidth="120" editable="false"/>
            <TableColumn fx:id="customerColumn" prefWidth="200" editable="false"/>
            <TableColumn fx:id="statusColumn" prefWidth="120" editable="false"/>
            <TableColumn fx:id="dueDateColumn" prefWidth="100" editable="false"/>
            <TableColumn fx:id="createdColumn" prefWidth="140" editable="false"/>
            <TableColumn fx:id="totalPriceColumn" prefWidth="100" editable="false"/>
            <TableColumn fx:id="amountPaidColumn" prefWidth="100" editable="false"/>
            <TableColumn fx:id="remainingColumn" prefWidth="100" editable="false"/>
            <TableColumn fx:id="notesColumn" prefWidth="400" editable="false"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
    
    <!-- Bottom: Status bar and Actions -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5;">
        <Label fx:id="statusLabel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"/>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="viewDetailsButton" onAction="#handleViewDetails" disable="true"/>
        <Button fx:id="changeStatusButton" onAction="#handleChangeStatusButton" disable="true"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="statusHistoryButton" onAction="#handleViewStatusHistory" disable="false"/>
        <Button fx:id="printButton" onAction="#handlePrint" disable="true"/>
    </HBox>
    
</VBox>
